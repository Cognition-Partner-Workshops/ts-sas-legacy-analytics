# Example Databricks connection profile for the SAS banking migration project.
# Copy this file to ~/.dbt/profiles.yml and fill in your credentials.
# DO NOT commit real credentials to source control.

databricks_banking:
  target: dev
  outputs:
    dev:
      type: databricks
      catalog: banking_dev
      schema: stg_bank
      host: "{{ env_var('DATABRICKS_HOST') }}"
      http_path: "{{ env_var('DATABRICKS_HTTP_PATH') }}"
      token: "{{ env_var('DATABRICKS_TOKEN') }}"
      threads: 4

    prod:
      type: databricks
      catalog: banking_prod
      schema: stg_bank
      host: "{{ env_var('DATABRICKS_HOST') }}"
      http_path: "{{ env_var('DATABRICKS_HTTP_PATH') }}"
      token: "{{ env_var('DATABRICKS_TOKEN') }}"
      threads: 8
